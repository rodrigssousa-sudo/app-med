      .map((drug, index) => ({ drug, index, score: getDrugMatchScore(drug, value) }))
      .filter(({ score }) => score >= 0)
      .sort((a, b) => {
        if (b.score !== a.score) return b.score - a.score;
        return a.index - b.index;
      })[0]?.drug;
    if (best) setHomeCalc((prev) => ({ ...prev, drugId: best.id }));
    setHomeCalcResult(null);
    setHomeCalcClcr(null);
    setHomeCalcMessage("Dados alterados. Toque em Calcular dose para atualizar o resultado.");
  }

