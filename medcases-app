function translateVisibleDomText(root, language) {
  if (typeof document === "undefined" || language !== "es" || !root) return;
  const blockedTags = new Set(["SCRIPT", "STYLE", "TEXTAREA", "INPUT", "SELECT", "CODE", "PRE"]);
  const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
    acceptNode(node) {
      const parent = node.parentElement;
      if (!parent || blockedTags.has(parent.tagName)) return NodeFilter.FILTER_REJECT;
      const raw = node.nodeValue || "";
      if (!raw.trim() || raw.trim().length < 2) return NodeFilter.FILTER_REJECT;
      if (parent.closest("[data-no-auto-translate='true']")) return NodeFilter.FILTER_REJECT;
      return NodeFilter.FILTER_ACCEPT;
    },
  });

  const nodes = [];
  while (walker.nextNode()) nodes.push(walker.currentNode);
  nodes.forEach((node) => {
    const raw = node.nodeValue || "";
    const translated = translateTextLocal(raw, language);
    if (translated !== raw) node.nodeValue = translated;
  });

  translateDomAttributes(root, language);
}

function translateDomAttributes(root, language) {
  if (typeof document === "undefined" || language !== "es" || !root) return;
  const attrs = ["placeholder", "title", "aria-label", "alt"];
  const elements = root.querySelectorAll("[placeholder], [title], [aria-label], [alt]");
  elements.forEach((element) => {
    if (element.closest("[data-no-auto-translate='true']")) return;
    attrs.forEach((attr) => {
      const raw = element.getAttribute(attr);
      if (!raw || !raw.trim()) return;
      const translated = translateTextLocal(raw, language);
      if (translated !== raw) element.setAttribute(attr, translated);
    });
  });
}

