function splitCurrentMeds(text) {
  const normalized = String(text || "").replaceAll(";", ",").replaceAll(String.fromCharCode(10), ",");
  return normalized
    .split(",")
    .map((item) => item.trim())
    .filter(Boolean);
}

function findDrugByFreeText(text, availableDrugs = drugDatabase) {
  const normalized = normalizeText(text);
  if (!normalized) return null;
  return availableDrugs.find((drug) => {
    const aliases = drugAliases[drug.id] || [];
    return aliases.some((alias) => normalized.includes(normalizeText(alias))) || normalizeText(drug.name).includes(normalized) || normalized.includes(normalizeText(drug.name));
  });
}

function getInteractionRiskStyle(risk) {
  const r = normalizeText(risk);
  if (r.includes("alto")) return "bg-red-50 border-red-200 text-red-900";
  if (r.includes("moderado")) return "bg-amber-50 border-amber-200 text-amber-900";
  return "bg-red-50 border-red-100 text-red-900";
}

function checkCurrentMedicationInteractions(selectedDrug, currentMedicationText, availableDrugs = drugDatabase) {
  const meds = splitCurrentMeds(currentMedicationText).map((raw) => ({ raw, drug: findDrugByFreeText(raw, availableDrugs) }));
  if (!selectedDrug) return { knownMeds: meds, alerts: [] };

  const alerts = [];
  meds.forEach((med) => {
    if (!med.drug || med.drug.id === selectedDrug.id) return;
    const rule = interactionRules.find((item) =>
      (item.a === selectedDrug.id && item.b === med.drug.id) || (item.b === selectedDrug.id && item.a === med.drug.id)
    );
    if (rule) {
      alerts.push({
        currentName: med.raw,
        currentDrug: med.drug,
        risk: rule.risk,
        text: rule.text,
        action: rule.action,
      });
    }
  });

  selectedDrug.interactions?.forEach((text) => {
    meds.forEach((med) => {
      const raw = normalizeText(med.raw);
      const currentName = normalizeText(med.drug?.name || "");
      if (raw && (normalizeText(text).includes(raw) || (currentName && normalizeText(text).includes(currentName)))) {
        const already = alerts.some((a) => a.currentName === med.raw && a.text === text);
        if (!already) alerts.push({ currentName: med.raw, currentDrug: med.drug, risk: "Atenção", text, action: "Revisar dose, indicação, monitorização e sinais de toxicidade." });
      }
    });
  });

  return { knownMeds: meds, alerts };
}

function normalizeText(value) {
  return String(value || "").toLowerCase().trim();
}

function getDrugSearchText(drug) {
  return [drug.name, drug.className, getDrugCategory(drug), drug.defaultRoute, drug.warning, drug.fixedDose]
    .filter(Boolean)
    .join(" ")
    .toLowerCase();
}

function getDrugMatchScore(drug, query) {
  const q = normalizeText(query);
  if (!q) return 0;

  const name = normalizeText(drug.name);
  const id = normalizeText(drug.id);
  const category = normalizeText(getDrugCategory(drug));
  const className = normalizeText(drug.className);
  const searchText = getDrugSearchText(drug);
  const nameParts = name.replace("/", " ").replace("(", " ").replace(")", " ").replace("-", " ").split(" ");

  if (name.startsWith(q)) return 100;
  if (id.startsWith(q)) return 95;
  if (nameParts.some((part) => part.startsWith(q))) return 90;
  if (category.startsWith(q)) return 75;
  if (className.startsWith(q)) return 65;
  if (name.includes(q)) return 55;
  if (searchText.includes(q)) return 35;
  return -1;
}

function calculateDrugDose(drug, patient) {
  const weight = num(patient.weight);
  const age = num(patient.age);
  const sex = patient.sex || "não informado";

  if (!drug) return null;

  const flags = [];
  if (!weight && ["weight", "infusion"].includes(drug.doseType)) flags.push("Informe o peso para calcular dose por kg.");
  if (age >= 65 && drug.elderlyNote) flags.push("Idoso: " + drug.elderlyNote);
  if (!patient.sex) flags.push("Sexo não informado: alguns fármacos/protocolos podem exigir ajuste.");

  if (drug.doseType === "weight" && weight) {
    const dose = weight * drug.mgKg;
    return {
      numericDose: dose,
      main: roundSmart(dose) + " " + drug.unit + " por dose",
      exact: roundSmart(dose) + " " + drug.unit,
      detail: drug.mgKg + " mg/kg × " + weight + " kg. Frequência: " + (drug.frequency || "individualizar") + ".",
      patient: (age || "—") + " anos • " + sex + " • " + (weight || "—") + " kg",
      flags,
    };
  }

  if (drug.doseType === "infusion" && weight) {
    const start = weight * drug.mcgKgMinStart;
    const max = weight * drug.mcgKgMinMax;
    return {
      numericDose: max,
      main: roundSmart(start) + " a " + roundSmart(max) + " " + drug.unit,
      exact: "Iniciar em " + roundSmart(start) + " " + drug.unit + " e titular até " + roundSmart(max) + " " + drug.unit,
      detail: drug.mcgKgMinStart + "–" + drug.mcgKgMinMax + " mcg/kg/min × " + weight + " kg. Titular em bomba por resposta clínica.",
      patient: (age || "—") + " anos • " + sex + " • " + (weight || "—") + " kg",
      flags,
    };
  }

  return {
    numericDose: extractFirstNumber(drug.fixedDose),
    main: drug.fixedDose || "Dose fixa/protocolo dependente",
    exact: drug.fixedDose || "Individualizar",
    detail: drug.pediatricFormula && age && age < 18 ? "Pediatria: " + drug.pediatricFormula : "Dose depende da indicação, gravidade e protocolo local.",
    patient: (age || "—") + " anos • " + sex + " • " + (weight || "—") + " kg",
    flags,
  };
}

function extractFirstNumber(value) {
  const cleaned = String(value || "").replace(",", ".");
  const match = cleaned.match(new RegExp("[0-9]+(?:\\.[0-9]+)?"));
  return match ? Number(match[0]) : 0;
}

function getAdultMaxNumber(drug) {
  return extractFirstNumber(drug?.adultMax);
}

function getRouteSafetyAlert(drug) {
  const text = normalizeText((drug?.id || "") + " " + (drug?.name || "") + " " + (drug?.warning || "") + " " + (drug?.fixedDose || ""));
  const highRiskTerms = ["potassio", "potássio", "kcl", "fenitoina", "fenitoína", "nitroprussiato", "noradrenalina", "dobutamina", "vancomicina", "amiodarona", "bicarbonato", "calcio", "cálcio", "magnesio", "magnésio"];
  const fastIvDanger = text.includes("iv") && (text.includes("lento") || text.includes("infusão") || text.includes("infusao") || text.includes("bomba") || text.includes("extravasamento") || highRiskTerms.some((term) => text.includes(term)));

  if (!fastIvDanger) return null;
  return {
    title: "Atenção na administração IV",
    text: "Fármaco com risco se administrado rápido, em via inadequada ou sem monitorização. Conferir diluição, compatibilidade, acesso e protocolo antes de aplicar.",
  };
}

function extractVitalsFromText(rawText) {
  const text = String(rawText || "");
  const slash = String.fromCharCode(92);
  const ws = slash + "s*";
  const optSep = ws + "[:=-]?" + ws;

  const find = (label, pattern) => {
    const match = text.match(pattern);
    return match?.[1] ? label + " " + match[1].trim() : "";
  };

  const pa = find("PA", new RegExp("(?:PA|press[aã]o|presi[oó]n)" + optSep + "([0-9]{2,3}" + ws + "[x/]" + ws + "[0-9]{2,3})", "i"));
  const fc = find("FC", new RegExp("(?:FC|freq(?:u[eê]ncia)? card[ií]aca|frecuencia card[ií]aca)" + optSep + "([0-9]{2,3})", "i"));
  const fr = find("FR", new RegExp("(?:FR|freq(?:u[eê]ncia)? resp(?:irat[oó]ria)?|frecuencia respiratoria)" + optSep + "([0-9]{1,3})", "i"));
  const sat = find("SatO2", new RegExp("(?:SatO2|Sat|SpO2|satura[cç][aã]o|saturaci[oó]n)" + optSep + "([0-9]{2,3}%?)", "i"));
  const temp = find("T°", new RegExp("(?:T|Temp|temperatura)" + optSep + "([0-9]{2}(?:[,.][0-9])?)", "i"));
  const glicemia = find("Glicemia", new RegExp("(?:glicemia|glucemia|HGT|DX)" + optSep + "([0-9]{2,4})", "i"));

  const values = [pa, fc, fr, sat, temp, glicemia].filter(Boolean);
  return {
    pa,
    fc,
    fr,
    sat,
    temp,
    glicemia,
    summary: values.join(" • "),
  };
}

