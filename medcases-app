function getTreatmentSearchText(item) {
  return [item.condition, item.category, item.type, item.firstLine, item.goal, item.scheme, item.warning]
    .filter(Boolean)
    .join(" ")
    .toLowerCase();
}

function getTreatmentMatchScore(item, query) {
  const q = normalizeText(query);
  if (!q) return 0;
  const condition = normalizeText(item.condition);
  const category = normalizeText(item.category);
  const firstLine = normalizeText(item.firstLine);
  const all = getTreatmentSearchText(item);
  if (condition.startsWith(q)) return 100;
  if (category.startsWith(q)) return 80;
  if (firstLine.startsWith(q)) return 70;
  if (condition.includes(q)) return 60;
  if (all.includes(q)) return 35;
  return -1;
}

