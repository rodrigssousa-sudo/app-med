function escapeForRegExp(value) {
  const slash = String.fromCharCode(92);
  const specials = new Set([".", "*", "+", "?", "^", "$", "{", "}", "(", ")", "|", "[", "]", slash]);
  return Array.from(String(value || "")).map((ch) => specials.has(ch) ? slash + ch : ch).join("");
}

function normalizeLabNumber(value) {
  return String(value || "").trim().split(" ").join("").replaceAll(",", ".");
}

function extractLabResultsFromOcrText(rawText) {
  const text = String(rawText || "");
  const results = [];
  const slash = String.fromCharCode(92);
  const space = slash + "s*";
  const sep = space + "[:=–—-]?" + space;
  const number = "([0-9]{1,6}(?:[.,][0-9]{1,4})?)";

  LAB_EXAM_DEFINITIONS.forEach((exam) => {
    let best = null;
    exam.aliases.forEach((alias) => {
      if (best) return;
      const pattern = new RegExp("(?:^|[^a-zA-ZÀ-ÿ0-9])" + escapeForRegExp(alias) + sep + number, "i");
      const match = text.match(pattern);
      if (match?.[1]) {
        best = {
          id: makeId("lab"),
          key: exam.key,
          label: exam.label,
          value: normalizeLabNumber(match[1]),
          unit: exam.unit,
          source: "OCR",
          capturedAt: new Date().toISOString(),
        };
      }
    });
    if (best) results.push(best);
  });

  return results;
}

function buildLabSummary(results) {
  const list = Array.isArray(results) ? results : [];
  if (!list.length) return "Nenhum parâmetro laboratorial reconhecido automaticamente.";
  return list.map((item) => `${item.label}: ${item.value}${item.unit ? " " + item.unit : ""}`).join(" • ");
}

function mergeLabResults(previousResults, newResults) {
  const previous = Array.isArray(previousResults) ? previousResults : [];
  const incoming = Array.isArray(newResults) ? newResults : [];
  const byKey = new Map(previous.map((item) => [item.key, item]));
  incoming.forEach((item) => byKey.set(item.key, item));
  return Array.from(byKey.values());
}

function getSpeechRecognitionEngine() {
  if (typeof window === "undefined") return null;
  return window.SpeechRecognition || window.webkitSpeechRecognition || null;
}

function cleanVoiceText(text) {
  return String(text || "")
    .replace(new RegExp(" +", "g"), " ")
    .replace(" ,", ",")
    .replace(" .", ".")
    .replace(" ;", ";")
    .replace(" :", ":")
    .trim();
}

function appendVoiceValue(currentValue, transcript) {
  const clean = cleanVoiceText(transcript);
  if (!clean) return currentValue || "";
  const base = String(currentValue || "").trim();
  if (!base) return clean;
  return `${base}${String.fromCharCode(10)}${clean}`;
}

function VoiceDictationBox({ title = "Preenchimento por voz", subtitle = "Fale e envie o texto para o campo desejado", fields = [], defaultField, onInsert }) {
  const [target, setTarget] = useState(defaultField || fields[0]?.value || "");
  const [listening, setListening] = useState(false);
  const [preview, setPreview] = useState("");
  const recognitionRef = useRef(null);
  const supported = Boolean(getSpeechRecognitionEngine());

  function startVoice() {
    const Recognition = getSpeechRecognitionEngine();
    if (!Recognition) {
      setPreview("Reconhecimento de voz não disponível neste navegador. Teste no Chrome ou Edge.");
      return;
    }

    const recognition = new Recognition();
    recognition.lang = "pt-BR";
    recognition.interimResults = true;
    recognition.continuous = false;
    recognition.maxAlternatives = 1;
    recognitionRef.current = recognition;
    setPreview("Ouvindo...");
    setListening(true);

    let finalText = "";

    recognition.onresult = (event) => {
      let interimText = "";
      for (let i = event.resultIndex; i < event.results.length; i += 1) {
        const transcript = event.results[i][0]?.transcript || "";
        if (event.results[i].isFinal) finalText += ` ${transcript}`;
        else interimText += ` ${transcript}`;
      }
      setPreview(cleanVoiceText(`${finalText} ${interimText}`) || "Ouvindo...");
    };

    recognition.onerror = () => {
      setListening(false);
      setPreview("Não consegui captar a voz. Verifique a permissão do microfone e tente novamente.");
    };

    recognition.onend = () => {
      setListening(false);
      const clean = cleanVoiceText(finalText);
      if (clean) {
        onInsert(target, clean);
        setPreview(`Adicionado: ${clean}`);
      }
    };

    recognition.start();
  }

  function stopVoice() {
    recognitionRef.current?.stop?.();
    setListening(false);
  }

  return (
    <div className={cx("rounded-[1.4rem] bg-slate-950 text-white border border-slate-800 p-3 shadow-sm relative overflow-hidden", listening && "ring-4 ring-emerald-400/20")}> 
      {listening && <div className="absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_18%_20%,rgba(16,185,129,.28),transparent_18%),radial-gradient(circle_at_78%_35%,rgba(34,197,94,.22),transparent_16%),radial-gradient(circle_at_45%_88%,rgba(59,130,246,.18),transparent_20%)] animate-pulse" />}
      {listening && <div className="absolute right-4 bottom-4 flex items-end gap-1 opacity-80">{[8,14,22,16,10].map((h, i) => <span key={i} className="w-1.5 rounded-full bg-emerald-300 animate-bounce" style={{ height: h, animationDelay: `${i * 120}ms` }} />)}</div>}
      <div className="relative flex items-start justify-between gap-3 mb-3">
        <div>
          <p className="font-black tracking-[-.03em]">{title}</p>
          <p className="text-xs text-slate-300 mt-0.5">{subtitle}</p>
        </div>
        <span className={cx("rounded-full px-2.5 py-1 text-[10px] font-black", supported ? "bg-emerald-400/15 text-emerald-200" : "bg-amber-400/15 text-amber-200")}>{supported ? "Voz ativa" : "Indisponível"}</span>
      </div>

      <div className="relative grid grid-cols-[1fr_auto] gap-2">
        <select
          value={target}
          onChange={(e) => setTarget(e.target.value)}
          className="h-10 rounded-2xl bg-white/10 border border-white/10 px-3 outline-none text-xs font-bold text-white"
        >
          {fields.map((field) => (
            <option key={field.value} value={field.value} className="text-slate-950">{field.label}</option>
          ))}
        </select>
        <button
          type="button"
          onClick={listening ? stopVoice : startVoice}
          className={cx("h-10 px-4 rounded-2xl text-xs font-black transition", listening ? "bg-red-500 text-white" : "bg-white text-slate-950")}
        >
          {listening ? "Parar" : "Ditado"}
        </button>
      </div>

      <div className="relative mt-2 min-h-[40px] rounded-2xl bg-white/[.06] border border-white/10 p-2 text-xs text-slate-200 leading-relaxed">
        {preview || "Toque em Ditado, permita o microfone e fale. O texto será adicionado ao campo escolhido."}
      </div>
    </div>
  );
}

