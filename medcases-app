const CRITICAL_SMART_TERMS = [
  "urgência",
  "urgencia",
  "emergência",
  "emergencia",
  "óbito",
  "obito",
  "crítico",
  "critico",
  "choque",
  "sepse",
  "iam",
  "avc",
  "tep",
  "tvp",
  "hipotensão",
  "hipotensao",
  "hipoxemia",
  "insuficiência respiratória",
  "insuficiencia respiratoria",
  "ira",
  "hipercalemia",
  "sangramento",
];

function highlightClinicalTerms(rawText) {
  const raw = String(rawText || "");
  if (!raw) return null;

  const escaped = CRITICAL_SMART_TERMS
    .map((term) => escapeRegExpSafe(term))
    .sort((a, b) => b.length - a.length)
    .join("|");

  if (!escaped) return raw;

  const pattern = new RegExp("(" + escaped + ")", "gi");
  const parts = raw.split(pattern);

  return parts.map((part, index) => {
    const isCritical = CRITICAL_SMART_TERMS.some((term) => normalizeText(term) === normalizeText(part));
    if (!isCritical) return part;
    return (
      <span key={`${part}-${index}`} className="mx-0.5 rounded-md bg-red-100 px-1 py-0.5 font-black text-red-700 ring-1 ring-red-200">
        {part}
      </span>
    );
  });
}

function CompactText({ label, text }) {
