function LabImageImportPanel({ form, onChange }) {
  const [imageFile, setImageFile] = React.useState(null);
  const [preview, setPreview] = React.useState(null);
  const [ocrStatus, setOcrStatus] = React.useState("idle");
  const [ocrText, setOcrText] = React.useState(form.labRawText || "");
  const [extractedLabs, setExtractedLabs] = React.useState(extractLabResultsFromSimpleText(form.labRawText || form.exams || ""));

  function handleImage(file) {
    if (!file) return;
    setImageFile(file);
    setPreview(URL.createObjectURL(file));
    setOcrStatus("ready");
  }

  async function runOcr() {
    if (!imageFile) return;
    try {
      setOcrStatus("loading");
      const Tesseract = await loadTesseractJs();
      const result = await Tesseract.recognize(imageFile, "por+spa+eng");
      const text = result?.data?.text || "";
      const labs = extractLabResultsFromSimpleText(text);
      setOcrText(text);
      setExtractedLabs(labs);
      setOcrStatus("done");
    } catch (error) {
      setOcrStatus("error");
      setOcrText((prev) => prev || "Não foi possível extrair automaticamente. Cole o texto do laboratório aqui e use Extrair dados.");
    }
  }

  function extractFromManualText() {
    const labs = extractLabResultsFromSimpleText(ocrText);
    setExtractedLabs(labs);
    setOcrStatus("done");
  }

  function applyToCase() {
    const formatted = formatExtractedLabs(extractedLabs);
    const stamp = `Laboratório importado em ${formatDate(new Date().toISOString())}`;
    const block = [stamp, formatted || ocrText].filter(Boolean).join(String.fromCharCode(10));
    const currentExams = String(form.exams || "").trim();
    onChange("labRawText", ocrText);
    onChange("labExtracted", formatted);
    onChange("exams", currentExams ? `${currentExams}${String.fromCharCode(10)}${String.fromCharCode(10)}${block}` : block);
  }

  return (
    <div className="rounded-[1.4rem] bg-emerald-50/80 border border-emerald-100 p-3">
      <div className="flex items-center gap-2 mb-3">
        <div className="h-9 w-9 rounded-2xl bg-emerald-700 text-white grid place-items-center"><Camera size={18} /></div>
        <div>
          <h4 className="font-black">Laboratório por imagem</h4>
          <p className="text-xs text-slate-500">Envie imagem ou use a câmera, revise o OCR e aplique ao caso.</p>
        </div>
      </div>

      <div className="grid grid-cols-2 gap-2">
        <label className="h-11 rounded-2xl bg-white border border-emerald-100 text-emerald-800 text-xs font-black grid place-items-center cursor-pointer shadow-sm">
          Enviar imagem
          <input type="file" accept="image/*" className="hidden" onChange={(e) => handleImage(e.target.files?.[0])} />
        </label>
        <label className="h-11 rounded-2xl bg-emerald-700 text-white text-xs font-black grid place-items-center cursor-pointer shadow-sm">
          Abrir câmera
          <input type="file" accept="image/*" capture="environment" className="hidden" onChange={(e) => handleImage(e.target.files?.[0])} />
        </label>
      </div>

      {preview && (
        <div className="mt-3 rounded-2xl overflow-hidden border border-emerald-100 bg-white">
          <img src={preview} alt="Prévia do laboratório" className="w-full max-h-64 object-contain bg-slate-950" />
        </div>
      )}

      <div className="grid grid-cols-2 gap-2 mt-3">
        <button type="button" onClick={runOcr} disabled={!imageFile || ocrStatus === "loading"} className="h-11 rounded-2xl bg-slate-950 text-white text-xs font-black disabled:opacity-40">
          {ocrStatus === "loading" ? "Lendo imagem..." : "Extrair OCR"}
        </button>
        <button type="button" onClick={extractFromManualText} className="h-11 rounded-2xl bg-white border border-emerald-100 text-emerald-800 text-xs font-black">
          Extrair do texto
        </button>
      </div>

      {ocrStatus === "error" && (
        <div className="mt-3 rounded-2xl bg-amber-50 border border-amber-100 p-3 text-xs text-amber-900">
          OCR automático indisponível. A internet pode estar bloqueada ou a imagem está pouco legível. Cole o texto abaixo e extraia manualmente.
        </div>
      )}

      <Field label="Texto reconhecido / colar laboratório">
        <TextArea compact value={ocrText} onChange={(e) => setOcrText(e.target.value)} placeholder="Cole aqui ou extraia da imagem: Hb, leucócitos, plaquetas, creatinina, Na, K, glicose..." />
      </Field>

      <div className="rounded-2xl bg-white border border-emerald-100 p-3 mt-3">
        <div className="flex items-center justify-between gap-2 mb-2">
          <p className="text-xs font-black uppercase tracking-[.12em] text-emerald-700">Dados extraídos</p>
          <span className="rounded-full bg-emerald-50 px-2 py-1 text-[10px] font-black text-emerald-700">{Object.keys(extractedLabs || {}).length} itens</span>
        </div>
        {Object.keys(extractedLabs || {}).length === 0 ? (
          <p className="text-xs text-slate-500">Nenhum exame reconhecido ainda.</p>
        ) : (
          <div className="grid grid-cols-2 gap-2">
            {Object.entries(extractedLabs).map(([key, value]) => (
              <MiniData key={key} label={key} value={value} />
            ))}
          </div>
        )}
      </div>

      <button type="button" onClick={applyToCase} className="mt-3 w-full h-11 rounded-2xl bg-emerald-700 text-white text-xs font-black shadow-sm">
        Aplicar laboratório ao caso
      </button>
    </div>
  );
}

