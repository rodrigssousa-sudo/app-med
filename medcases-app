function LabImageExtractor({ labResults, labOcrText, onApply }) {
  const [busy, setBusy] = useState(false);
  const [progress, setProgress] = useState(0);
  const [preview, setPreview] = useState(null);
  const [ocrText, setOcrText] = useState(labOcrText || "");
  const [parsed, setParsed] = useState([]);
  const [error, setError] = useState("");

  async function readLabImage(file) {
    if (!file) return;
    setError("");
    setBusy(true);
    setProgress(0);
    setPreview(URL.createObjectURL(file));

    try {
      const TesseractModule = await import("tesseract.js");
      const Tesseract = TesseractModule.default || TesseractModule;
      const result = await Tesseract.recognize(file, "por+spa+eng", {
        logger: (m) => {
          if (m?.status === "recognizing text") setProgress(Math.round((m.progress || 0) * 100));
        },
      });
      const text = result?.data?.text || "";
      const results = extractLabResultsFromOcrText(text);
      setOcrText(text);
      setParsed(results);
      if (!results.length) setError("Li a imagem, mas não consegui reconhecer parâmetros laboratoriais claros. Você pode revisar o texto e aplicar manualmente.");
    } catch (err) {
      setError("Não consegui executar OCR neste navegador. Tente uma foto mais nítida, PNG/JPG, ou ative internet para carregar o motor OCR.");
    } finally {
      setBusy(false);
    }
  }

  function applyParsed() {
    const results = parsed.length ? parsed : extractLabResultsFromOcrText(ocrText);
    onApply({ results, text: ocrText });
  }

  return (
    <div className="rounded-[1.4rem] bg-gradient-to-br from-emerald-50 to-white border border-emerald-100 p-3">
      <div className="flex items-start justify-between gap-3 mb-3">
        <div>
          <h4 className="font-black tracking-[-.03em]">OCR de laboratório</h4>
          <p className="text-xs text-slate-500">Envie foto ou print do laboratório, revise e aplique ao paciente.</p>
        </div>
        <span className="rounded-full bg-emerald-100 text-emerald-700 px-2.5 py-1 text-[10px] font-black">LAB IA</span>
      </div>

      <label className="cursor-pointer rounded-2xl border-2 border-dashed border-emerald-200 bg-white p-3 flex items-center gap-3">
        <div className="h-11 w-11 rounded-2xl bg-emerald-950 text-white grid place-items-center"><Camera size={18} /></div>
        <div className="flex-1 min-w-0">
          <p className="text-sm font-black">Enviar imagem do laboratório</p>
          <p className="text-xs text-slate-500 truncate">JPG, PNG ou print do resultado</p>
        </div>
        <input type="file" accept="image/*" className="hidden" onChange={(e) => readLabImage(e.target.files?.[0])} />
      </label>

      {preview && (
        <div className="mt-3 overflow-hidden rounded-2xl border border-slate-200 bg-white">
          <img src={preview} alt="Prévia do laboratório" className="max-h-48 w-full object-contain bg-slate-50" />
        </div>
      )}

      {busy && (
        <div className="mt-3 rounded-2xl bg-emerald-950 text-white p-3">
          <div className="flex items-center justify-between text-xs font-black mb-2">
            <span>Lendo imagem...</span>
            <span>{progress}%</span>
          </div>
          <div className="h-2 rounded-full bg-white/15 overflow-hidden">
            <div className="h-full bg-emerald-300 transition-all" style={{ width: `${progress}%` }} />
          </div>
        </div>
      )}

      {error && <div className="mt-3 rounded-2xl bg-amber-50 border border-amber-100 p-3 text-xs text-amber-900 font-bold">{error}</div>}

      {(parsed.length > 0 || labResults?.length > 0) && (
        <div className="mt-3 grid grid-cols-2 gap-2">
          {(parsed.length ? parsed : labResults).map((item) => (
            <div key={item.id || item.key} className="rounded-2xl bg-white border border-emerald-100 p-2">
              <p className="text-[10px] font-black uppercase text-emerald-700 truncate">{item.label}</p>
              <p className="text-base font-black text-slate-950">{item.value} <span className="text-xs text-slate-500">{item.unit}</span></p>
            </div>
          ))}
        </div>
      )}

      {ocrText && (
        <Field label="Texto reconhecido para revisão">
          <TextArea compact value={ocrText} onChange={(e) => {
            const text = e.target.value;
            setOcrText(text);
            setParsed(extractLabResultsFromOcrText(text));
          }} />
        </Field>
      )}

      <div className="grid grid-cols-2 gap-2 mt-3">
        <button type="button" onClick={() => setParsed(extractLabResultsFromOcrText(ocrText))} className="h-10 rounded-2xl bg-white border border-emerald-100 text-emerald-700 text-xs font-black">
          Reanalisar texto
        </button>
        <button type="button" disabled={!ocrText && !parsed.length} onClick={applyParsed} className="h-10 rounded-2xl bg-emerald-600 text-white text-xs font-black disabled:opacity-40">
          Aplicar ao caso
        </button>
      </div>
    </div>
  );
}

