  function handleDrugSearchChange(value) {
    setDrugSearch(value);
    const q = value.trim();
    if (!q) return;

    const bestMatch = allDrugs
      .map((drug, index) => ({ drug, index, score: getDrugMatchScore(drug, q) }))
      .filter(({ drug, score }) => {
        const categoryOk = drugCategory === "Todos" || getDrugCategory(drug) === drugCategory;
        return categoryOk && score >= 0;
      })
      .sort((a, b) => {
        if (b.score !== a.score) return b.score - a.score;
        return a.index - b.index;
      })[0];

    if (bestMatch?.drug?.id) openDrugTranslated(bestMatch.drug.id);
  }

