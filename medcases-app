function MiniTrend({ title, suffix, values }) {
  const valid = values.filter((item) => Number.isFinite(item.value));
  if (!valid.length) return null;
  const max = Math.max(...valid.map((item) => item.value), 1);
  const last = valid[valid.length - 1];
  const first = valid[0];
  const direction = last.value > first.value ? "↑" : last.value < first.value ? "↓" : "→";
  return (
    <div className="rounded-2xl bg-slate-50 border border-slate-100 p-3">
      <div className="flex items-center justify-between gap-2 mb-2">
        <p className="text-xs font-black uppercase tracking-[.12em] text-slate-500">{title}</p>
        <span className="text-xs font-black text-slate-700">{direction} {last.value} {suffix}</span>
      </div>
      <div className="flex items-end gap-1 h-20">
        {valid.map((item, index) => (
          <div key={`${item.label}-${index}`} className="group flex-1 flex flex-col items-center gap-1">
            <div
              title={`${item.label}: ${item.value} ${suffix}`}
              className="w-full rounded-t-xl bg-emerald-600/80 min-h-[6px] origin-bottom transition-transform duration-200 group-hover:scale-y-110 group-hover:bg-emerald-500"
              style={{ height: `${Math.max(8, (item.value / max) * 68)}px` }}
            />
            <span className="text-[9px] font-bold text-slate-400 truncate max-w-[42px]">{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  );
}

