    ["diagnostico", "diagnóstico"], ["hipotesis", "hipótesis"], ["examen fisico", "examen físico"], ["fisico", "físico"],
    ["tratameto", "tratamiento"], ["paciete", "paciente"], ["frecuencia", "frecuencia"], ["observaciones", "observaciones"],
    ["necesario", "necesario"], ["historico", "histórico"], ["clinico", "clínico"], ["clinica", "clínica"],
