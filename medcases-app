    const result = calculateDrugDose(drug, homeCalc);
    const clcrResult = homeCalc.creatinine ? calculateClCr(homeCalc, homeCalc.creatinine) : null;
    setHomeCalcResult(result);
    setHomeCalcClcr(clcrResult);

    if (["weight", "infusion"].includes(drug.doseType) && !num(homeCalc.weight)) {
      setHomeCalcMessage("Esse fármaco depende do peso. Informe o peso e calcule novamente.");
      return;
    }

    setHomeCalcMessage(homeCalc.creatinine ? "Dose calculada com estimativa de ClCr." : "Dose calculada sem creatinina. ClCr ficou opcional.");
