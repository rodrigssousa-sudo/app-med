function translateAnyValue(value, targetLang = "pt") {
  return Promise.resolve(translateAnyValueSync(value, targetLang));
}

function translateAnyValueSync(value, targetLang = "pt") {
  if (targetLang === "pt") return value;
  if (typeof value === "string") return translateTextLocal(value, targetLang);
  if (Array.isArray(value)) return value.map((item) => translateAnyValueSync(item, targetLang));
  if (value && typeof value === "object") return Object.fromEntries(Object.entries(value).map(([key, val]) => [key, translateAnyValueSync(val, targetLang)]));
  return value;
}

function getTextField(rawText, labels = []) {
  const lines = String(rawText || "").split(String.fromCharCode(10)).map((line) => line.trim()).filter(Boolean);
  const normalizedLabels = labels.map((label) => normalizeText(label));
  for (const line of lines) {
    const normalizedLine = normalizeText(line);
    const found = normalizedLabels.find((label) => normalizedLine.startsWith(label + ":") || normalizedLine.startsWith(label + " -") || normalizedLine.startsWith(label + "="));
    if (found) {
      const colon = line.indexOf(":");
      const eq = line.indexOf("=");
      const dash = line.indexOf("-");
      const indexes = [colon, eq, dash].filter((n) => n >= 0);
      const cut = indexes.length ? Math.min(...indexes) : -1;
      return cut >= 0 ? line.slice(cut + 1).trim() : "";
    }
  }
  return "";
}

function splitListField(value) {
  return String(value || "").replaceAll(";", ",").replaceAll(String.fromCharCode(10), ",").split(",").map((item) => item.trim()).filter(Boolean);
}

function slugifyId(prefix, value) {
  const plain = String(value || "personalizado").normalize("NFD").split("").filter((char) => {
    const code = char.charCodeAt(0);
    return code < 768 || code > 879;
  }).join("");
  const base = plain.toLowerCase().split("").map((char) => /[a-z0-9]/.test(char) ? char : "-").join("").split("-").filter(Boolean).join("-").slice(0, 48);
  return `${prefix}_${base || makeId("item")}`;
}

