function validateCustomBase(customDrugs = [], customTreatments = []) {
  const issues = [];
  customDrugs.forEach((drug) => {
    if (!drug.name) issues.push("Fármaco personalizado sem nome.");
    if (!drug.className) issues.push(`${drug.name || "Fármaco"}: falta classe.`);
    if (!drug.fixedDose) issues.push(`${drug.name || "Fármaco"}: falta dose/posologia.`);
    if (!drug.warning) issues.push(`${drug.name || "Fármaco"}: falta alerta principal.`);
  });
  customTreatments.forEach((tx) => {
    if (!tx.condition) issues.push("Tratamento personalizado sem síndrome/doença.");
    if (!tx.firstLine) issues.push(`${tx.condition || "Tratamento"}: falta primeira linha.`);
    if (!tx.scheme) issues.push(`${tx.condition || "Tratamento"}: falta esquema.`);
    if (!tx.warning) issues.push(`${tx.condition || "Tratamento"}: falta alerta.`);
  });
  return issues;
}

