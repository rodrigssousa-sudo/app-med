    ["antibiotico", "antibiótico"], ["antiinflamatorio", "anti-inflamatório"], ["analgesico", "analgésico"], ["diuretico", "diurético"]
  ],
  es: [
    ["enfermedade", "enfermedad"], ["enfermedades", "enfermedades"], ["sindrome", "síndrome"], ["sindromes", "síndromes"],
    ["farmaco", "fármaco"], ["farmacos", "fármacos"], ["evolucion", "evolución"], ["funcion", "función"],
