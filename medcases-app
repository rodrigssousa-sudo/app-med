function detectTypingLanguage(text, appLanguage = "pt") {
  const value = String(text || "").toLowerCase();
  if (!value.trim()) return appLanguage === "es" ? "es" : "pt";

  const ptHits = ["ção", "ções", "não", "você", "paciente", "tratamento", "conduta", "evolução", "exames", "dor", "febre", "pressão", "coração", "medicação", "fármaco", "após", "também"]
    .reduce((sum, word) => sum + (value.includes(word) ? 1 : 0), 0);
  const esHits = ["ción", "ciones", "no ", "usted", "paciente", "tratamiento", "conducta", "evolución", "exámenes", "dolor", "fiebre", "presión", "corazón", "medicación", "fármaco", "después", "también"]
    .reduce((sum, word) => sum + (value.includes(word) ? 1 : 0), 0);

  if (esHits > ptHits) return "es";
  if (ptHits > esHits) return "pt";
  return appLanguage === "es" ? "es" : "pt";
}

const LOCAL_SPELL_FIXES = {
