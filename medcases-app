function cx(...classes) {
  return classes.filter(Boolean).join(" ");
}

function formatDate(value) {
  if (!value) return "—";
  return new Intl.DateTimeFormat("pt-BR", {
    day: "2-digit",
    month: "2-digit",
    year: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  }).format(new Date(value));
}

function extractFirstNumberFromText(text) {
  const raw = String(text || "");
  let started = false;
  let out = "";
  for (let i = 0; i < raw.length; i += 1) {
    const ch = raw[i];
    const isDigit = ch >= "0" && ch <= "9";
    const isDecimal = ch === "," || ch === ".";
    if (isDigit || (started && isDecimal)) {
      started = true;
      out += ch === "," ? "." : ch;
    } else if (started) {
      break;
    }
  }
  return out || "";
}

function normalizeLabTextLine(line) {
  return String(line || "")
    .toLowerCase()
    .normalize("NFD")
    .split("")
    .filter((ch) => ch < "̀" || ch > "ͯ")
    .join("")
    .replaceAll(":", " ")
    .replaceAll("=", " ")
    .replaceAll(";", " ")
    .trim();
}

function findLabValue(lines, labels) {
  const found = lines.find((line) => labels.some((label) => line.includes(label)));
  return found ? extractFirstNumberFromText(found) : "";
}

function extractLabResultsFromSimpleText(rawText) {
  const lines = String(rawText || "")
    .split(String.fromCharCode(10))
    .map(normalizeLabTextLine)
    .filter(Boolean);

  const result = {
    hemoglobina: findLabValue(lines, ["hemoglobina", " hb ", "hb ", " hb"]),
    hematocrito: findLabValue(lines, ["hematocrito", "hto", " hct"]),
    leucocitos: findLabValue(lines, ["leucocitos", "leucocito", "globulos blancos", "wbc"]),
    plaquetas: findLabValue(lines, ["plaquetas", "plaq", "platelets"]),
    creatinina: findLabValue(lines, ["creatinina", "creat", "crea"]),
    urea: findLabValue(lines, ["urea", "bun"]),
    sodio: findLabValue(lines, ["sodio", "na ", " na", "natremia"]),
    potassio: findLabValue(lines, ["potassio", "potasio", "k ", " k", "kalemia"]),
    glicose: findLabValue(lines, ["glicose", "glucose", "glucemia", "glicemia"]),
    pcr: findLabValue(lines, ["proteina c reativa", "pcr", "crp"]),
    tgo: findLabValue(lines, ["tgo", "ast"]),
    tgp: findLabValue(lines, ["tgp", "alt"]),
    bilirrubina: findLabValue(lines, ["bilirrubina total", "bt ", "bil total"]),
    inr: findLabValue(lines, ["inr", "rni"]),
  };

  return Object.entries(result)
    .filter(([, value]) => Boolean(value))
    .map(([key, value]) => ({ key, value }))
    .reduce((acc, item) => ({ ...acc, [item.key]: item.value }), {});
}

function formatExtractedLabs(labs) {
  const labels = {
    hemoglobina: "Hemoglobina",
    hematocrito: "Hematócrito",
    leucocitos: "Leucócitos",
    plaquetas: "Plaquetas",
    creatinina: "Creatinina",
    urea: "Urea",
    sodio: "Sódio/Na+",
    potassio: "Potássio/K+",
    glicose: "Glicose",
    pcr: "PCR",
    tgo: "TGO/AST",
    tgp: "TGP/ALT",
    bilirrubina: "Bilirrubina total",
    inr: "INR/RNI",
  };
  const entries = Object.entries(labs || {});
  if (!entries.length) return "";
  return entries.map(([key, value]) => `${labels[key] || key}: ${value}`).join(String.fromCharCode(10));
}

function loadTesseractJs() {
  if (typeof window === "undefined") return Promise.reject(new Error("Navegador indisponível."));
  if (window.Tesseract) return Promise.resolve(window.Tesseract);

  return new Promise((resolve, reject) => {
    const existing = document.querySelector("script[data-medcases-ocr='true']");
    if (existing) {
      existing.addEventListener("load", () => resolve(window.Tesseract));
      existing.addEventListener("error", () => reject(new Error("Falha ao carregar OCR.")));
      return;
    }

    const script = document.createElement("script");
    script.src = "https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js";
    script.async = true;
    script.dataset.medcasesOcr = "true";
    script.onload = () => resolve(window.Tesseract);
    script.onerror = () => reject(new Error("Falha ao carregar OCR pela internet."));
    document.body.appendChild(script);
  });
}

function formatShortDate(value) {
  if (!value) return "—";
  return new Intl.DateTimeFormat("pt-BR", { day: "2-digit", month: "2-digit" }).format(new Date(value));
}

function escapeHtml(value) {
  return String(value ?? "")
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#039;");
}

function textToHtml(value) {
  const clean = String(value || "").trim();
  if (!clean) return "<span class='empty'>Não informado.</span>";
  return escapeHtml(clean)
    .replaceAll(String.fromCharCode(13), "")
    .split(String.fromCharCode(10))
    .join("<br />");
}

function formatReportDate(value) {
  if (!value) return "Não informado";
  try {
    return new Intl.DateTimeFormat("pt-BR", {
      day: "2-digit",
      month: "2-digit",
      year: "numeric",
      hour: "2-digit",
      minute: "2-digit",
    }).format(new Date(value));
  } catch {
    return String(value);
  }
}

function getReportTitle(type) {
  const titles = {
    case: "Relatório de Caso Clínico",
    evolution: "Relatório de Evolução Clínica",
    treatment: "Relatório Terapêutico do Paciente",
    complete: "História Clínica Completa",
  };
  return titles[type] || titles.complete;
}

function getReportFileName(caseItem, type, ext) {
  const code = String(caseItem?.patientCode || caseItem?.title || "paciente")
    .normalize("NFD")
    .split("")
    .filter((char) => {
      const codePoint = char.charCodeAt(0);
      return codePoint < 768 || codePoint > 879;
    })
    .join("")
    .replace(new RegExp("[^a-zA-Z0-9]+", "g"), "-")
    .replace(new RegExp("(^-)|(-$)", "g"), "")
    .toLowerCase();
  const prefix = type === "case" ? "caso-clinico" : type === "evolution" ? "evolucao" : type === "treatment" ? "tratamento" : "historia-clinica";
  return `${prefix}-${code || "paciente"}.${ext}`;
}

