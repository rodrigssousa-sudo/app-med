function escapeRegExpSafe(value) {
  const source = String(value || "");
  const specials = new Set([".", "*", "+", "?", "^", "$", "{", "}", "(", ")", "|", "[", "]", String.fromCharCode(92)]);
  let escaped = "";

  for (const char of source) {
    escaped += specials.has(char) ? String.fromCharCode(92) + char : char;
  }

  return escaped;
}

function applyLocalSpellingFixes(text, lang) {
  let output = String(text || "");
  const rules = LOCAL_SPELL_FIXES[lang] || LOCAL_SPELL_FIXES.pt;
  const boundary = String.fromCharCode(92) + "b";

  rules.forEach(([from, to]) => {
    const escaped = escapeRegExpSafe(from);
    const pattern = new RegExp(boundary + escaped + boundary, "gi");

    output = output.replace(pattern, (match) => {
      if (match.toUpperCase() === match) return to.toUpperCase();
      if (match[0] === match[0]?.toUpperCase()) {
        return to.charAt(0).toUpperCase() + to.slice(1);
      }
      return to;
    });
  });

  return output;
}

function applyLanguageToolMatches(text, matches) {
  let output = String(text || "");
  const sorted = [...(matches || [])]
    .filter((match) => match?.replacements?.[0]?.value)
    .sort((a, b) => b.offset - a.offset);

  sorted.forEach((match) => {
    const replacement = match.replacements[0].value;
    output = output.slice(0, match.offset) + replacement + output.slice(match.offset + match.length);
  });
  return output;
}

function emitCorrectedValue(onChange, corrected) {
  if (typeof onChange === "function") {
    onChange({ target: { value: corrected } });
  }
}

function SpellCorrectionHint({ value, onChange, compact = false }) {
  const [detectedLang, setDetectedLang] = useState("pt");
  const [suggestedText, setSuggestedText] = useState("");
  const [checking, setChecking] = useState(false);
  const [source, setSource] = useState("");

  useEffect(() => {
    let cancelled = false;
    const rawText = String(value || "");
    const trimmed = rawText.trim();
    const lang = detectTypingLanguage(rawText);
    setDetectedLang(lang);

    if (trimmed.length < 8) {
      setSuggestedText("");
      setSource("");
      setChecking(false);
      return;
    }

    const localFixed = applyLocalSpellingFixes(rawText, lang);
    if (localFixed !== rawText) {
      setSuggestedText(localFixed);
      setSource("local");
    }

    const timer = window.setTimeout(async () => {
      setChecking(true);
      try {
        const body = new URLSearchParams();
        body.set("text", rawText);
        body.set("language", lang === "es" ? "es" : "pt-BR");

        const response = await fetch("https://api.languagetool.org/v2/check", {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body,
        });
        if (!response.ok) throw new Error("spell-check-failed");
        const data = await response.json();
        const onlineFixed = applyLanguageToolMatches(rawText, data?.matches || []);
        const finalText = onlineFixed !== rawText ? onlineFixed : localFixed;
        if (!cancelled) {
          setSuggestedText(finalText !== rawText ? finalText : "");
          setSource(onlineFixed !== rawText ? "online" : finalText !== rawText ? "local" : "");
        }
      } catch {
        if (!cancelled) {
          setSuggestedText(localFixed !== rawText ? localFixed : "");
          setSource(localFixed !== rawText ? "local" : "");
        }
      } finally {
        if (!cancelled) setChecking(false);
      }
    }, 900);

    return () => {
      cancelled = true;
      window.clearTimeout(timer);
    };
  }, [value]);

  if (!String(value || "").trim() || (!suggestedText && !checking)) return null;

  return (
    <div className={cx("mt-1.5 rounded-2xl border p-2", suggestedText ? "bg-emerald-50 border-emerald-100" : "bg-slate-50 border-slate-100")}>
      <div className="flex items-center justify-between gap-2">
        <p className="text-[10px] font-black uppercase tracking-[.12em] text-slate-500">
          Idioma detectado: {detectedLang === "es" ? "Espanhol" : "Português"} {checking ? "• verificando..." : source ? `• correção ${source}` : ""}
        </p>
        {suggestedText && (
          <button
            type="button"
            onClick={() => emitCorrectedValue(onChange, suggestedText)}
            className="h-8 px-3 rounded-xl bg-emerald-700 text-white text-[11px] font-black shrink-0"
          >
            Corrigir texto
          </button>
        )}
      </div>
      {suggestedText && !compact && (
        <p className="mt-1 text-xs text-emerald-900 line-clamp-2">
          Sugestão: {suggestedText}
        </p>
      )}
    </div>
  );
}

