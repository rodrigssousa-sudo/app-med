function extractTrendNumber(text, labels) {
  const value = String(text || "");
  const numberSplitter = new RegExp("[^0-9.]+");

  for (const label of labels) {
    const idx = value.toLowerCase().indexOf(String(label).toLowerCase());
    if (idx < 0) continue;

    const fragment = value.slice(idx, idx + 36).replace(",", ".");
    const firstNumber = fragment.split(numberSplitter).filter(Boolean)[0];
    const parsed = Number(firstNumber);

    if (Number.isFinite(parsed)) return parsed;
  }

  return null;
}

function getEvolutionTrendItems(caseItem) {
  const evolutions = [...(caseItem?.dailyEvolutions || [])].sort((a, b) => String(a.date || "").localeCompare(String(b.date || "")));
  return evolutions.map((ev, index) => {
    const combined = [ev.vitals, ev.labs, ev.response, ev.conduct].filter(Boolean).join(" | ");
    return {
      label: ev.day || formatShortDate(ev.date) || `D${index + 1}`,
      creatinine: extractTrendNumber(combined, ["creatinina", "creat", "cr"]),
      pa: extractTrendNumber(combined, ["pa", "pressão", "presión"]),
      sat: extractTrendNumber(combined, ["sat", "spo2", "sato2"]),
    };
  });
}

